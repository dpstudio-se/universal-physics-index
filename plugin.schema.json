{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VR-ASI-1 Plugin Manifest",
  "type": "object",
  "required": ["pluginId", "version", "name", "runtime", "mode", "enabled", "permissions", "resources"],
  "properties": {
    "pluginId": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "name": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "runtime": {"type": "string", "enum": ["node", "python", "docker"]},
    "mode": {"type": "string", "enum": ["simulation", "executable"]},
    "enabled": {"type": "boolean"},
    "entryPoint": {"type": "string", "minLength": 1},
    "permissions": {
      "type": "object",
      "required": ["defaultDeny", "capabilities"],
      "properties": {
        "defaultDeny": {"const": true},
        "capabilities": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["resource", "actions", "scopes"],
            "properties": {
              "resource": {"type": "string", "enum": ["filesystem", "network", "exec", "kv", "model"]},
              "actions": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
              "scopes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "resources": {
      "type": "object",
      "required": ["cpu", "memory"],
      "properties": {
        "cpu": {"type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$"},
        "memory": {"type": "string", "pattern": "^[0-9]+(Mi|Gi)$"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {"properties": {"mode": {"const": "executable"}}},
      "then": {"required": ["entryPoint"]}
    }
  ]
}
