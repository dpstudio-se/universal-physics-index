{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VR-ASI-1 Plugin Manifest",
  "type": "object",
  "properties": {
    "pluginId": {
      "type": "string",
      "description": "Unique identifier for the plugin (e.g., 'oden-core')"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the plugin"
    },
    "name": {
      "type": "string",
      "description": "Human-readable name of the plugin"
    },
    "description": {
      "type": "string",
      "description": "Brief description of the plugin's purpose"
    },
    "entryPoint": {
      "type": "string",
      "description": "The main file or command to start the plugin"
    },
    "runtime": {
      "type": "string",
      "enum": ["node", "python", "docker"],
      "description": "The execution environment required"
    },
    "permissions": {
      "type": "object",
      "properties": {
        "file": { "type": "boolean", "description": "Access to the filesystem" },
        "network": { "type": "boolean", "description": "Allow network access" },
        "exec": { "type": "boolean", "description": "Allow execution of shell commands" },
        "kv": { "type": "boolean", "description": "Access to the key-value store" },
        "models": { "type": "boolean", "description": "Access to LLM models" }
      },
      "required": ["file", "network", "exec", "kv", "models"]
    },
    "resources": {
      "type": "object",
      "properties": {
        "cpu": { "type": "string", "description": "CPU limit (e.g., '0.5')" },
        "memory": { "type": "string", "description": "Memory limit (e.g., '512Mi')" }
      }
    }
  },
  "required": ["pluginId", "version", "name", "entryPoint", "runtime", "permissions"]
}
