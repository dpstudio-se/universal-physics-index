{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UPI Agent Workflow Specification",
  "type": "object",
  "required": ["workflow_id", "version", "status", "roles", "states", "transitions", "invariants", "confusion_guard"],
  "properties": {
    "workflow_id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "status": {"const": "SYM"},
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role_id", "agent_class", "default_deny", "capabilities"],
        "properties": {
          "role_id": {"type": "string", "minLength": 1},
          "agent_class": {"type": "string", "enum": ["coordinator", "transport", "reviewer", "repair", "quarantine"]},
          "default_deny": {"const": true},
          "capabilities": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
        },
        "additionalProperties": false
      }
    },
    "states": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "enum": ["QUEUED", "LEASED", "RUNNING", "SUCCEEDED", "FAILED", "TIMED_OUT", "QUARANTINED", "CANCELLED"]}
    },
    "transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "condition"],
        "properties": {
          "from": {"type": "string"},
          "to": {"type": "string"},
          "condition": {"type": "string", "minLength": 1},
          "independent_review": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "invariants": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "confusion_guard": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
