{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dpstudio-se/universal-physics-index/schemas/node.schema.json",
  "title": "UPI Node v0.1.0-alpha",
  "type": "object",
  "required": ["address", "title", "description", "scientific_domain", "status", "schema_version"],
  "properties": {
    "address": {
      "type": "object",
      "required": ["domain", "generation", "torus", "node"],
      "properties": {
        "domain": {"type": "string", "minLength": 1},
        "generation": {"type": "string", "minLength": 1},
        "torus": {"type": "string", "minLength": 1},
        "node": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "title": {"type": "string", "minLength": 1},
    "description": {"type": "string", "minLength": 1},
    "scientific_domain": {"type": "string", "minLength": 1},
    "status": {"enum": ["EST", "DER", "HYP", "STOP", "ERR", "SYM"]},
    "schema_version": {"const": "0.1.0"},
    "equation": {"type": ["string", "null"]},
    "variables": {"type": "object", "additionalProperties": {"type": "string"}},
    "quantities": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/quantity"}
    },
    "assumptions": {"type": "array", "items": {"type": "string"}},
    "evidence_level": {"enum": ["none", "low", "moderate", "high", "consensus"]},
    "provenance": {"type": "array", "items": {"$ref": "#/$defs/provenance"}},
    "references": {"type": "array", "items": {"type": "string"}},
    "dependencies": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "parent_ids": {"type": "array", "items": {"type": "string"}},
    "child_ids": {"type": "array", "items": {"type": "string"}},
    "supersedes": {"type": "array", "items": {"type": "string"}},
    "superseded_by": {"type": "array", "items": {"type": "string"}},
    "evidence_links": {"type": "array", "items": {"type": "string"}},
    "normalization_method": {"type": ["string", "null"]},
    "reference_frame": {"type": ["string", "null"]},
    "normalization_claim": {"enum": ["coordinate_only", "numerical_similarity", "structural_similarity", "physical_equivalence", null]},
    "uncertainty": {"type": ["string", "null"]},
    "test_method": {"type": ["string", "null"]},
    "predicted_observation": {"type": ["string", "null"]},
    "falsification_condition": {"type": ["string", "null"]},
    "required_dataset": {"type": ["string", "null"]},
    "measurable_variable": {"type": ["string", "null"]},
    "null_model": {"type": ["string", "null"]},
    "control_condition": {"type": ["string", "null"]},
    "statistical_method": {"type": ["string", "null"]},
    "confounders": {"type": "array", "items": {"type": "string"}},
    "replication_rule": {"type": ["string", "null"]},
    "causal_claim": {"type": "boolean"},
    "causal_test_method": {"type": ["string", "null"]},
    "verification_type": {"enum": ["software_test", "simulation", "mathematical_check", "experimental_observation", "replication", "none"]},
    "claims_experimental_verification": {"type": "boolean"},
    "testability": {"enum": ["current", "future", null]},
    "symbolic_interpretation": {"type": ["string", "null"]},
    "notes": {"type": "array", "items": {"type": "string"}},
    "confusion_guard": {"type": "array", "items": {"type": "string"}},
    "stop_reason": {"type": ["string", "null"]},
    "source_hashes": {"type": "array", "items": {"type": "string"}},
    "revision_history": {"type": "array", "items": {"type": "object"}},
    "created_date": {"type": "string", "format": "date"},
    "revised_date": {"type": "string", "format": "date"}
  },
  "$defs": {
    "quantity": {
      "type": "object",
      "required": ["nominal_value", "unit"],
      "properties": {
        "nominal_value": {"type": "number"},
        "unit": {"type": "string", "minLength": 1},
        "frequency_type": {
          "enum": ["photon_frequency", "angular_frequency", "oscillation_frequency", "sampling_frequency", "repetition_rate", "resonance_frequency", "carrier_frequency", "biological_rhythm", "symbolic_reference_frequency", "numerical_normalization_frequency", "rest_mass_frequency", null]
        },
        "standard_uncertainty": {"type": ["number", "null"], "minimum": 0},
        "confidence_interval": {"type": ["array", "null"], "prefixItems": [{"type": "number"}, {"type": "number"}], "minItems": 2, "maxItems": 2},
        "uncertainty_type": {"type": ["string", "null"]},
        "measurement_method": {"type": ["string", "null"]},
        "sample_size": {"type": ["integer", "null"], "minimum": 1},
        "source": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": ["source_type", "source_status"],
      "properties": {
        "source_type": {"type": "string", "minLength": 1},
        "source_status": {"enum": ["peer_reviewed", "preprint", "dataset", "textbook", "standard", "official_document", "personal_note", "unknown"]},
        "author": {"type": ["string", "null"]}, "doi": {"type": ["string", "null"]},
        "arxiv_id": {"type": ["string", "null"]}, "url": {"type": ["string", "null"]},
        "citation": {"type": ["string", "null"]}, "dataset_id": {"type": ["string", "null"]},
        "git_commit": {"type": ["string", "null"]}, "publication_date": {"type": ["string", "null"]},
        "retrieval_date": {"type": ["string", "null"]}, "page_reference": {"type": ["string", "null"]},
        "source_hash": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {"if": {"properties": {"status": {"const": "HYP"}}}, "then": {"anyOf": [
      {"required": ["test_method"]}, {"required": ["predicted_observation"]},
      {"required": ["falsification_condition"]}, {"required": ["required_dataset"]},
      {"required": ["measurable_variable"]}, {"properties": {"testability": {"const": "future"}}, "required": ["testability"]}
    ]}},
    {"if": {"properties": {"status": {"enum": ["EST", "DER", "HYP"]}}}, "then": {"required": ["provenance"], "properties": {"provenance": {"minItems": 1}}}}
  ],
  "additionalProperties": false
}
