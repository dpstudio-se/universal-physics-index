{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UPI Agent Task Envelope",
  "type": "object",
  "required": [
    "task_id", "workflow_id", "role_id", "state", "idempotency_key",
    "payload_hash", "capabilities", "default_deny", "attempt", "max_attempts",
    "created_at", "deadline_at"
  ],
  "properties": {
    "task_id": {"type": "string", "minLength": 1},
    "workflow_id": {"type": "string", "minLength": 1},
    "role_id": {"type": "string", "minLength": 1},
    "correlation_id": {"type": "string", "minLength": 1},
    "parent_task_id": {"type": "string", "minLength": 1},
    "state": {
      "type": "string",
      "enum": ["QUEUED", "LEASED", "RUNNING", "SUCCEEDED", "FAILED", "TIMED_OUT", "QUARANTINED", "CANCELLED"]
    },
    "idempotency_key": {"type": "string", "minLength": 1},
    "payload_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["resource", "actions", "scopes"],
        "properties": {
          "resource": {"type": "string", "enum": ["filesystem", "network", "kv", "model", "exec"]},
          "actions": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "scopes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
        },
        "additionalProperties": false
      }
    },
    "default_deny": {"const": true},
    "attempt": {"type": "integer", "minimum": 0},
    "max_attempts": {"type": "integer", "minimum": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "deadline_at": {"type": "string", "format": "date-time"},
    "lease_owner": {"type": "string", "minLength": 1},
    "lease_expires_at": {"type": "string", "format": "date-time"},
    "result_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "failure_code": {"type": "string", "minLength": 1},
    "quarantine_reason": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {"properties": {"state": {"enum": ["LEASED", "RUNNING"]}}},
      "then": {"required": ["lease_owner", "lease_expires_at"]}
    },
    {
      "if": {"properties": {"state": {"const": "SUCCEEDED"}}},
      "then": {"required": ["result_hash"]}
    },
    {
      "if": {"properties": {"state": {"const": "QUARANTINED"}}},
      "then": {"required": ["quarantine_reason"]}
    }
  ]
}
