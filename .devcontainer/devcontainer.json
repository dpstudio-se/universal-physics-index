{
  "name": "UPI Codespace",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["tests"],
        "editor.formatOnSave": true
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff"
      ]
    }
  },
  "postCreateCommand": "python -m pip install --upgrade pip setuptools wheel && pip install -e '.[dev]'",
  "postStartCommand": "python --version && upi --help > /dev/null",
  "remoteUser": "vscode"
}
